# Copy to .env and fill in. docker-compose reads this file automatically.
# NOTE: the real .env is gitignored — never commit secrets.

# Gemini API key — enables live agent runs. Leave blank to run seed/ingest/UI only.
GEMINI_API_KEY=

# Bearer token the agent presents to the attack-runners' MCP endpoint.
SPELLBOOK_RUNNER_TOKEN=dev-token

# --- usually left at the compose defaults ---------------------------------
# SPELLBOOK_DATABASE_URL=postgresql+psycopg://spellbook:spellbook@db:5432/spellbook
# SPELLBOOK_SCOPE=example.com,shop.example.com,10.4.0.0/16
# SPELLBOOK_SEED=1
