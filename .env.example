# Copy to .env and fill in. docker-compose reads this file automatically.
# NOTE: the real .env is gitignored — never commit secrets.

# Anthropic API key — enables live agent-worker runs. Leave blank to run
# seed/ingest/UI only (workers idle-poll until a key + a dispatched run exist).
ANTHROPIC_API_KEY=

# Shared bearer token the agent-workers present on the control plane's /internal API.
SPELLBOOK_WORKER_TOKEN=dev-token

# --- usually left at the compose defaults ---------------------------------
# SPELLBOOK_DATABASE_URL=postgresql+psycopg://spellbook:spellbook@db:5432/spellbook
# SPELLBOOK_SCOPE=example.com,shop.example.com,10.4.0.0/16
# SPELLBOOK_SEED=1
# SPELLBOOK_AGENT_MODEL=claude-opus-4-8
